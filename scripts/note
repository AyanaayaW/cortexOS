#!/usr/bin/env bash
# note — Generate a study note from any AI tool
# Usage: note <model> <subject> "<topic>" [type]
#
#   model   : claude | gemini | ollama | ollama/<name>
#   subject : subject folder name (e.g. Physics, Math)
#   topic   : topic name
#   type    : note type (default: concept-note)
#
# Examples:
#   note claude  Physics "Newton's Laws"
#   note gemini  Math    "Integration by Parts"
#   note ollama  Chem    "Organic Reactions"  summary
#   note ollama/mistral Economics "Supply and Demand"

set -euo pipefail

MODEL="${1:-}"
SUBJECT="${2:-}"
TOPIC="${3:-}"
TYPE="${4:-concept-note}"
DATE="$(date +%Y-%m-%d)"
VAULT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
OUTPUT_DIR="$VAULT_DIR/AI Outputs/Notes/$SUBJECT"

if [[ -z "$MODEL" || -z "$SUBJECT" || -z "$TOPIC" ]]; then
  echo "Usage: note <model> <subject> \"<topic>\" [type]"
  echo "  model: claude | gemini | ollama | ollama/<name>"
  echo "  type defaults to: concept-note"
  exit 1
fi

mkdir -p "$OUTPUT_DIR"

OUTPUT_FILE="$OUTPUT_DIR/$DATE $TOPIC — $TYPE.md"
SUBJECT_TAG="$(echo "$SUBJECT" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')"
TOPIC_TAG="$(echo "$TOPIC"   | tr '[:upper:]' '[:lower:]' | tr ' ' '-')"
MODEL_SOURCE="$(echo "$MODEL" | cut -d'/' -f1)"

PROMPT="You are an expert tutor. Generate a comprehensive study note for a student.

Subject: $SUBJECT
Topic: $TOPIC
Note type: $TYPE

Requirements:
- Begin with YAML frontmatter:
  ---
  title: \"$TOPIC\"
  subject: \"$SUBJECT\"
  type: $TYPE
  date: $DATE
  tags: [$SUBJECT_TAG, $TOPIC_TAG]
  source: $MODEL_SOURCE
  reviewed: false
  ---
- LaTeX for ALL equations (inline: \$...\$, block: \$\$...\$\$)
- Mark every high-priority point with ⭐
- Sections: Overview, Key Concepts, Equations, ⭐ Key Points, Common Mistakes, Practice Questions
- End with 3–5 exam-style questions with mark allocations e.g. [4 marks]
- Concise — no filler. Prefer tables over bullet lists."

echo "note [$MODEL] $SUBJECT / $TOPIC …"

# ── Route to model ────────────────────────────────────────────────────────────
case "$MODEL" in

  claude)
    if ! command -v claude &>/dev/null; then
      echo "Error: 'claude' not found — install at https://claude.ai/code"; exit 1
    fi
    claude --print "$PROMPT" > "$OUTPUT_FILE"
    ;;

  gemini)
    if ! command -v gemini &>/dev/null; then
      echo "Error: 'gemini' not found — run: npm install -g @google/gemini-cli"; exit 1
    fi
    gemini -p "$PROMPT" > "$OUTPUT_FILE"
    ;;

  ollama|ollama/*)
    OLLAMA_MODEL="${MODEL#ollama/}"
    [[ "$OLLAMA_MODEL" == "ollama" ]] && OLLAMA_MODEL="llama3.2"
    if ! command -v jq &>/dev/null; then
      echo "Error: 'jq' not found — run: brew install jq"; exit 1
    fi
    if ! curl -sf http://localhost:11434/api/tags &>/dev/null; then
      echo "Error: Ollama not running — start with: ollama serve"; exit 1
    fi
    RESPONSE=$(curl -sf http://localhost:11434/api/generate \
      -H "Content-Type: application/json" \
      -d "$(jq -n --arg m "$OLLAMA_MODEL" --arg p "$PROMPT" \
            '{model:$m,prompt:$p,stream:false}')" \
      | jq -r '.response')
    [[ -z "$RESPONSE" ]] && { echo "Error: empty response — is '$OLLAMA_MODEL' pulled? Run: ollama pull $OLLAMA_MODEL"; exit 1; }
    printf '%s\n' "$RESPONSE" > "$OUTPUT_FILE"
    ;;

  *)
    echo "Error: unknown model '$MODEL'"
    echo "Valid options: claude | gemini | ollama | ollama/<name>"
    exit 1
    ;;
esac

echo "✅ Saved to: $OUTPUT_FILE"
