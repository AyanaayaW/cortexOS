#!/usr/bin/env bash
# explain — Get an explanation from any AI tool
# Usage: explain <model> "<question-or-filepath>" [subject]
#
#   model   : claude | gemini | ollama | ollama/<name>
#   input   : a text question, OR a path to a file (PDF / txt / md)
#   subject : optional label for output folder (default: General)
#
# Examples:
#   explain claude  "What is Newton's second law?"
#   explain gemini  "chapter5.pdf"  Chemistry
#   explain ollama  "Explain entropy"
#   explain ollama/mistral "What is a p-value?" Stats

set -euo pipefail

MODEL="${1:-}"
INPUT="${2:-}"
SUBJECT="${3:-General}"
DATE="$(date +%Y-%m-%d)"
VAULT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
OUTPUT_DIR="$VAULT_DIR/AI Outputs/Explanations"

if [[ -z "$MODEL" || -z "$INPUT" ]]; then
  echo "Usage: explain <model> \"<question-or-filepath>\" [subject]"
  echo "  model: claude | gemini | ollama | ollama/<name>"
  exit 1
fi

mkdir -p "$OUTPUT_DIR"

# ── Resolve file vs. question ─────────────────────────────────────────────────
IS_FILE=false
if [[ -f "$INPUT" ]]; then
  IS_FILE=true
  FILE_ABS="$(cd "$(dirname "$INPUT")" && pwd)/$(basename "$INPUT")"
  FILE_DIR="$(dirname "$FILE_ABS")"
  FILE_NAME="$(basename "$FILE_ABS")"
fi

SLUG="$(echo "$INPUT" | cut -c1-60 | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd '[:alnum:]-')"
OUTPUT_FILE="$OUTPUT_DIR/$DATE $SLUG.md"

SUBJECT_TAG="$(echo "$SUBJECT" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')"

# ── Build prompt ──────────────────────────────────────────────────────────────
if $IS_FILE; then
  PROMPT="You are an expert tutor. Read and explain the content of '$FILE_NAME' for a student studying $SUBJECT. Be concise and precise. Use LaTeX for all equations (inline: \$...\$, block: \$\$...\$\$). Mark key points with ⭐."
else
  PROMPT="You are an expert tutor. Explain the following for a student studying $SUBJECT. Be concise. Use LaTeX for all equations (inline: \$...\$, block: \$\$...\$\$). Mark important points with ⭐.

Question: $INPUT"
fi

FRONTMATTER="---
title: \"$(echo "$INPUT" | cut -c1-80)\"
type: explanation
model: $MODEL
date: $DATE
tags: [explanation, $SUBJECT_TAG]
source: $(echo "$MODEL" | cut -d'/' -f1)
reviewed: false
---

> **Input:** $INPUT

---
"

echo "explain [$MODEL] …"

# ── Route to model ────────────────────────────────────────────────────────────
case "$MODEL" in

  claude)
    if ! command -v claude &>/dev/null; then
      echo "Error: 'claude' not found — install at https://claude.ai/code"; exit 1
    fi
    { printf '%s\n' "$FRONTMATTER"; claude --print "$PROMPT"; } > "$OUTPUT_FILE"
    ;;

  gemini)
    if ! command -v gemini &>/dev/null; then
      echo "Error: 'gemini' not found — run: npm install -g @google/gemini-cli"; exit 1
    fi
    if $IS_FILE; then
      { printf '%s\n' "$FRONTMATTER"; gemini --include-directories "$FILE_DIR" -p "$PROMPT"; } > "$OUTPUT_FILE"
    else
      { printf '%s\n' "$FRONTMATTER"; gemini -p "$PROMPT"; } > "$OUTPUT_FILE"
    fi
    ;;

  ollama|ollama/*)
    OLLAMA_MODEL="${MODEL#ollama/}"
    [[ "$OLLAMA_MODEL" == "ollama" ]] && OLLAMA_MODEL="llama3.2"
    if ! command -v jq &>/dev/null; then
      echo "Error: 'jq' not found — run: brew install jq"; exit 1
    fi
    if ! curl -sf http://localhost:11434/api/tags &>/dev/null; then
      echo "Error: Ollama not running — start with: ollama serve"; exit 1
    fi
    if $IS_FILE; then
      FILE_EXT="${FILE_ABS##*.}"
      if [[ "$FILE_EXT" == "pdf" ]] && command -v pdftotext &>/dev/null; then
        FILE_BODY="$(pdftotext "$FILE_ABS" -)"
      else
        FILE_BODY="$(cat "$FILE_ABS" 2>/dev/null || echo "[could not read file]")"
      fi
      PROMPT="$PROMPT

--- FILE CONTENT: $FILE_NAME ---
$FILE_BODY"
    fi
    RESPONSE=$(curl -sf http://localhost:11434/api/generate \
      -H "Content-Type: application/json" \
      -d "$(jq -n --arg m "$OLLAMA_MODEL" --arg p "$PROMPT" \
            '{model:$m,prompt:$p,stream:false}')" \
      | jq -r '.response')
    [[ -z "$RESPONSE" ]] && { echo "Error: empty response — is '$OLLAMA_MODEL' pulled? Run: ollama pull $OLLAMA_MODEL"; exit 1; }
    printf '%s\n\n%s\n' "$FRONTMATTER" "$RESPONSE" > "$OUTPUT_FILE"
    ;;

  *)
    echo "Error: unknown model '$MODEL'"
    echo "Valid options: claude | gemini | ollama | ollama/<name>"
    exit 1
    ;;
esac

echo "✅ Saved to: $OUTPUT_FILE"
